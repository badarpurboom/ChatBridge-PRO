# ─── SimpleWA CRM — Environment Variables ───
# Copy this file to .env and fill in your values
# KABHI BHI .env file ko git mein commit mat karo!

# Django
SECRET_KEY=django-insecure-aapka-secret-key-yahan-likho-change-this
DJANGO_SETTINGS_MODULE=config.settings.dev

# Redis (Memurai on Windows, or Redis on Linux)
REDIS_URL=redis://127.0.0.1:6379/0

# Internal webhook secret (wa-service aur Django ke beech)
INTERNAL_WEBHOOK_SECRET=change-this-to-random-string-abc123xyz

# WhatsApp service URL
WA_SERVICE_URL=http://localhost:3000

# ─── Production only ───
# DB_NAME=simplewa_crm
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432
# ALLOWED_HOSTS=yourdomain.com
# CORS_ORIGINS=https://yourdomain.com
